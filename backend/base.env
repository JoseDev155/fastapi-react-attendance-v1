# JWT - Tokens de acceso
ALGORITHM=
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# Encriptacion
CRYPT_SCHEME=
ENCODING=

# CORS - URLs permitidas para acceso desde frontend
# Formato: URL1,URL2,URL3 (separadas por coma, sin espacios)
# Ejemplos:
#   Desarrollo: http://localhost:3000,http://localhost:8080
#   Produccion: https://midominio.com,https://www.midominio.com
CORS_ORIGINS=

# Rate Limiting - Límites de solicitudes por tiempo
# Formato: numero/unidad (minute, hour, day)
# Desarrollo: límites más altos, Producción: más restrictivos
RATE_LIMIT_LOGIN=
RATE_LIMIT_REGISTER=
RATE_LIMIT_REFRESH=

# Configuracion de la base de datos
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_NAME=
DB_PYTHON_DRIVER=